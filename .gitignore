# ML Models and Large Data Files
# Training/test datasets can be regenerated or stored in cloud storage
backend/app/models/data/*.csv
# ML model binaries - can be large and regenerated
*.joblib
*.pkl
*.h5
*.model
*.weights
*.pb
*.onnx
*.pt
*.pth
# Keep the pipeline script but not the trained models
!backend/app/models/*_pipeline.py
!backend/app/models/feature_utils.py

# IMPORTANT: Keep these files - they're needed for the app to work
# Re-add essential data files
!backend/app/data/merged_dataset.csv
!backend/distributed-data/*.csv
# Re-add the trained ML model (needed for predictions)
!backend/app/models/rf_pipeline_broad.joblib

