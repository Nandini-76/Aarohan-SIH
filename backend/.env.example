# Backend environment variables
# Set these securely in Render dashboard

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=cluster-name
DB_NAME=dropout_prediction

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Use specific domains for production, localhost for development
FRONTEND_URL=http://localhost:3000,http://localhost:5173,https://arohann.vercel.app,https://aarohan.vercel.app

# Optional: Use regex for dynamic Vercel preview deployments
# FRONTEND_URL_REGEX=^https://.*\.vercel\.app$

# Development Settings
DEBUG=false
LOG_LEVEL=INFO
