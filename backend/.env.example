# Backend environment variables
# Set these securely in Render dashboard

# MongoDB Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=cluster-name
DB_NAME=dropout_prediction

# CORS Configuration
# Comma-separated list of allowed origins for CORS
# Use specific domains for production, localhost for development
FRONTEND_URL=http://localhost:3000,http://localhost:5173,https://arohann.vercel.app,https://aarohan.vercel.app

# Optional: Use regex for dynamic Vercel preview deployments
# FRONTEND_URL_REGEX=^https://.*\.vercel\.app$

# Development Settings
DEBUG=false
LOG_LEVEL=INFO

# =============================================================================
# EMAIL SERVICE (Optional - for sending PDF reports)
# =============================================================================
# If not configured, reports will still be generated but not emailed

# Gmail Configuration (Recommended)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587

# Alternative SMTP Providers
# For Outlook: MAIL_SERVER=smtp-mail.outlook.com
# For Yahoo: MAIL_SERVER=smtp.mail.yahoo.com

# =============================================================================
# REPORT SETTINGS (Optional)
# =============================================================================
# Number of days to keep generated reports before auto-cleanup
REPORT_RETENTION_DAYS=7

# =============================================================================
# NOTES
# =============================================================================
# 1. Copy this file to .env and fill in your actual values
# 2. NEVER commit .env to version control
# 3. For Gmail: Use App Password, not your regular password
#    - Enable 2FA: https://myaccount.google.com/security
#    - Generate App Password: https://myaccount.google.com/apppasswords
# 4. Email service is optional - reports work without it
