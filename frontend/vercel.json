{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "package.json", "use": "@vercel/static-build" }
  ],
  "build": {
    "env": {
      "VITE_API_BASE_URL": "${VITE_API_BASE_URL}"
    }
  },
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
